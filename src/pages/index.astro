                                    </div>

                                    <div class="grid gap-3 sm:grid-cols-3">
                                        <div
                                            class="rounded-3xl border border-white/10 bg-white/[0.04] p-5"
                                        >
                                            <p
                                                class="text-3xl font-semibold tracking-tight"
                                            >
