---
import "../styles/global.css";
---

<!-- Below is your "component template." It's just HTML, but with
    some magic sprinkled in to help you build great templates. --><!doctype html>
<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>OrbitOps — SaaS Landing Page</title>
        <meta
            name="description"
            content="A premium SaaS landing page built with Tailwind CSS."
        />
        <style>
            .noise:before {
                content: "";
                position: fixed;
                inset: 0;
                pointer-events: none;
                opacity: 0.06;
                background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
                z-index: 80;
            }
            .mask-fade {
                -webkit-mask-image: linear-gradient(
                    to bottom,
                    black 68%,
                    transparent
                );
                mask-image: linear-gradient(to bottom, black 68%, transparent);
            }
        </style>
    </head>

    <body
        class="noise bg-black text-white antialiased selection:bg-ember-500/30 selection:text-white"
    >
        <!-- Top promo strip -->
        <div
            class="relative z-50 border-b border-white/10 bg-ember-500/95 px-4 py-2 text-center text-sm font-medium text-black"
        >
            Launch faster with OrbitOps AI. Start free today, upgrade when your
            team scales.
        </div>

        <!-- Navigation -->
        <header
            class="sticky top-0 z-40 border-b border-white/10 bg-black/65 backdrop-blur-2xl"
        >
            <nav
                class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 lg:px-8"
            >
                <a href="#" class="flex items-center gap-3">
                    <span
                        class="grid h-8 w-8 place-items-center rounded-full bg-white text-sm font-black text-black"
                        >O</span
                    >
                    <span class="text-sm font-semibold tracking-wide text-white"
                        >OrbitOps</span
                    >
                </a>

                <div
                    class="hidden items-center gap-8 text-sm text-white/64 md:flex"
                >
                    <a class="transition hover:text-white" href="#features"
                        >Platform</a
                    >
                    <a class="transition hover:text-white" href="#workflow"
                        >Workflow</a
                    >
                    <a class="transition hover:text-white" href="#pricing"
                        >Pricing</a
                    >
                    <a class="transition hover:text-white" href="#faq">FAQ</a>
                </div>

                <div class="flex items-center gap-3">
                    <a
                        href="#"
                        class="hidden text-sm font-medium text-white/70 transition hover:text-white sm:inline"
                        >Sign in</a
                    >
                    <a
                        href="#pricing"
                        class="rounded-full bg-white px-4 py-2 text-sm font-semibold text-black transition hover:bg-white/90"
                    >
                        Buy
                    </a>
                </div>
            </nav>
        </header>

        <main>
            <!-- Hero -->
            <section class="relative overflow-hidden bg-radial-orange">
                <div
                    class="absolute inset-x-0 top-0 h-72 bg-gradient-to-b from-ember-500/20 to-transparent"
